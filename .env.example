# EdgeRadar configuration — copy to `.env` and fill in. NEVER commit `.env`.
#   cp .env.example .env
#
# Phase 0 works with the defaults below; the credential lines stay blank until
# the phase that needs them. Anything left blank that is later required will make
# the app fail loudly rather than silently misbehave.

# --- Object storage (MinIO) -------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=edgeradar
MINIO_ROOT_PASSWORD=edgeradar-dev-secret    # CHANGE ME for anything non-local
MINIO_BUCKET=edgeradar

# --- Warehouse / lake paths -------------------------------------------------
DUCKDB_PATH=data/warehouse/edgeradar.duckdb
DATA_ROOT=data

# --- Kalshi (Phase 1; account required, 18+) --------------------------------
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=                 # from your Kalshi account API settings
KALSHI_PRIVATE_KEY_PATH=           # path to your RSA private key file (git-ignored)

# --- Manifold (Phase 1; no auth needed for public reads) --------------------
MANIFOLD_API_BASE=https://api.manifold.markets/v0

# --- The Odds API (sportsbook lines; free tier ~500 req/mo — cache hard) -----
ODDS_API_BASE=https://api.the-odds-api.com/v4
ODDS_API_KEY=                      # free key from the-odds-api.com

# --- National Weather Service (no key; requires descriptive User-Agent) ------
NWS_API_BASE=https://api.weather.gov
NWS_USER_AGENT=EdgeRadar (contact: ethan.rm.wang@gmail.com)

# --- Alerting (Phase 7) -----------------------------------------------------
DISCORD_WEBHOOK_URL=               # create a webhook in your Discord channel settings

# --- Hard guardrail: this system is read-only. Leave as false. --------------
ENABLE_ORDER_EXECUTION=false
